 206          /* ====================== зҹ©йҳөй”®зӣҳ ====================== */
 207          
 208          unsigned char Key_Scan(void)
 209          {
 210   1          unsigned char col, row_data, key = 0;
 211   1      
 212   1          P1 = 0xF0;
 213   1          _nop_(); _nop_();
 214   1          if ((P1 & 0xF0) == 0xF0) return 0;
 215   1      
 216   1          for (col = 0; col < 4; col++) {
 217   2              P1 = (~(1 << col) & 0x0F) | 0xF0;
 218   2              _nop_(); _nop_();
 219   2              row_data = P1 & 0xF0;
 220   2              if (row_data != 0xF0) {
 221   3                  if      (!(row_data & 0x80)) key = col + 1;
 222   3                  else if (!(row_data & 0x40)) key = col + 5;
 223   3                  else if (!(row_data & 0x20)) key = col + 9;
 224   3                  else if (!(row_data & 0x10)) key = col + 13;
 225   3                  break;
 226   3              }
 227   2          }
 228   1      
 229   1          P1 = 0xF0;                     /* йҮҠж”ҫ P1, йҒҝе…Қз”өжңәиҜҜеҠЁ */
 230   1          return key;
 231   1      }
 232          
 233          unsigned char Key_WaitPress(void)
 234          {
 235   1          unsigned char raw;
 236   1      
C51 COMPILER V9.59.0.0   MAIN                                                              05/11/2026 13:05:59 PAGE 5   

 237   1          while (1) {
 238   2              raw = Key_Scan();
 239   2              if (raw != 0) {
 240   3                  Delay_ms(20);
 241   3                  if (Key_Scan() == raw) break;  /* ж¶ҲжҠ–зЎ®и®Ө */
 242   3              }
 243   2          }
 244   1      
 245   1          /* зӯүжҢүй”®йҮҠж”ҫ */
 246   1          while (Key_Scan() != 0);
 247   1          Delay_ms(20);
 248   1      
 249   1          /* жҢүй”®йҮҠж”ҫеҗҺжүҚеҸ‘еЈ°, йҒҝе…ҚиңӮйёЈеҷЁе№Іжү°й”®зӣҳжү«жҸҸ */
 250   1          Beep_Start(BEEP_KEY, 3);       /* 60ms жҢүй”®йҹі */
 251   1      
 252   1          /* й”®еҖјжҳ е°„ */
 253   1          if (raw >= 1 && raw <= 9)  return '0' + raw;
 254   1          if (raw == 10)             return '0';
 255   1          if (raw == 11)             return 'E';
 256   1          if (raw == 12)             return 'C';
 257   1          return 0;
 258   1      }
